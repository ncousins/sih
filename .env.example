# Supabase — get from supabase.com project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (used by Supabase CLI for migrations)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Site URL — your Vercel production URL
NEXT_PUBLIC_SITE_URL=https://sih.bpesa.org.za

# Resend — get from resend.com
RESEND_API_KEY=re_your_key

# Paystack — get from dashboard.paystack.com → Settings → API Keys & Webhooks
# Use sk_test_* / pk_test_* for testing, sk_live_* / pk_live_* for production
PAYSTACK_SECRET_KEY=sk_live_your_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
